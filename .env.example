# CBC Insider — no password stored. Run `python login.py` once to log in
# manually; your session is saved to the file below and reused each day.
CBC_URL=https://www.cbcinsider.com
# Strongly recommended: paste the exact URL of your dispatch/queue page (the
# one ending in dispatch.aspx) from your browser's address bar. The scraper
# goes straight there; without it, it can't reliably find your queue.
CBC_QUEUE_URL=https://www.cbcinsider.com/intranet/offsyte/dispatch.aspx
# Optional but recommended: the Work Center your queue is filtered to (e.g.
# ENGGL). If set, the run aborts with a clear error rather than silently
# scraping a different Work Center should the site's selection ever drift.
CBC_WORK_CENTER=
# Backfill only (backfill_orders.py): the queue page's "search order" box is
# auto-detected. If detection misses on your layout, set its exact CSS selector
# here (run `python discover_documents.py --probe <job#>` to print it), and set
# CBC_SEARCH_BUTTON if a separate button — not Enter — submits the search.
#CBC_SEARCH_SELECTOR=#MainContent_txtFindOrder
#CBC_SEARCH_BUTTON=#MainContent_btnFindOrder

# --- Drawing-transmittal tooling (transmittal_data.py / transmittal_doc.py /
#     fill_transmittal_insider.py) -----------------------------------------------
# The transmittal tools fill the Word doc and can PRE-FILL the CBC Insider
# "Email Drawings" form, but SENDING is hard-disabled in code — nothing is ever
# mailed to a customer automatically. These are only used to pre-fill the form
# for a human to review and submit by hand.
# TRANSMITTAL_MODE stays "preview"; "send" is intentionally inert in this build.
#TRANSMITTAL_MODE=preview
# The Email Drawings flow is two pages — page 1 takes the order #, page 2 is the
# email form with the Send button. Fill these in after running
# `python fill_transmittal_insider.py --probe` (page 1) and `--probe --order <#>` (page 2).
#EMAIL_DRAWINGS_URL=
# Page 1 (order lookup):
#EMAIL_DRAWINGS_ORDER_SELECTOR=
#EMAIL_DRAWINGS_ORDER_SUBMIT_SELECTOR=   # leave blank to advance with Enter
# Page 2 (email form):
#EMAIL_DRAWINGS_EMAILS_SELECTOR=
#EMAIL_DRAWINGS_ATTACH_SELECTOR=
#EMAIL_DRAWINGS_SUBMIT_SELECTOR=         # the Send button — never auto-clicked

# Where the saved login session is stored (created by login.py).
STORAGE_STATE_PATH=./cbc_session.json

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Where to save the daily Excel files and JSON snapshots. Defaults to
# %USERPROFILE%\Documents\DailyQueue on Windows — uncomment + edit only if
# you want them somewhere else.
#OUTPUT_DIR=%USERPROFILE%\Documents\DailyQueue
#SNAPSHOT_DIR=%USERPROFILE%\Documents\DailyQueue\snapshots

# Where downloaded sales-order PDFs are archived (one subfolder per job).
# Defaults to the Z: drive share below. For the scheduled 5 AM task a UNC path
# (\\server\share\DAG\SALES ORDERS FOR DAILY QUEUE) is more reliable than a
# mapped drive letter.
#SALES_ORDER_DIR=Z:\DAG\SALES ORDERS FOR DAILY QUEUE
# Where downloaded construction/drive-run PDFs are archived (one subfolder per
# job). Only the highly-custom orders that have a quote/drive run get one.
#DRIVE_RUN_DIR=Z:\DAG\DRIVE RUNS FOR DAILY QUEUE
# How quote runs are recognized. Only HDX fans file the run under its own pid
# type (DRIVE_RUN_TYPES, comma-separated, case-insensitive, leading CBC_
# optional; any other doc type ending in "Run" also counts). Everything else
# files it under a generic type like CBC_Inquiry, recognizable only by FILE
# NAME — DRIVE_RUN_NAME_PATTERNS is a comma-separated list of case-insensitive
# regexes matched against document/file names, both in the order's documents
# and in the job's AutoCAD folder (searched recursively, e.g. ENG REF\
# "420410 qt  run.txt"). Extend the patterns as new namings turn up; run
# `python discover_documents.py <job#>` to see what a job carries. The default
# "wheel"/"construction" tokens are intentionally broad (grab-and-flag beats
# missing a run): an over-grab that parses to nothing is just a NO FIELDS row,
# and it can't outrank a real run's data (see run_rank.py). Tighten these if a
# job folder holds construction docs you don't want treated as runs.
#DRIVE_RUN_TYPES=CBC_DriveRun,CBC_QuoteRun
#DRIVE_RUN_NAME_PATTERNS=qt\s*run,quote\s*run,wheel,construction
# Where the backlog tools (autocad_scan.py, backfill_orders.py) keep their
# resumable progress stores and master workbooks. Defaults under OUTPUT_DIR.
#BACKLOG_DIR=%USERPROFILE%\Documents\DailyQueue\backlog
# Root of the AutoCAD job folders (for the DWG scan + folder links).
#AUTOCAD_JOBS_DIR=Z:\AUTOCAD\CURRENT\JOBS
# Root of the SolidWorks job folders (solidworks_scan.py — the "Has 3D" data).
#SOLIDWORKS_JOBS_DIR=Z:\Solidworks\Current\JOBS
# How many order-detail pop-ups to open in parallel when fetching sales orders
# (each takes ~30s to load). Default 8. Raise cautiously and watch the server.
#SO_CONCURRENCY=8

# Sales-order LINE ITEMS: every parsed order's item/feature lines are captured,
# normalized, and stored for lookup (search with find_orders.py; build/tune the
# store with line_items_scan.py). Where the JSON store lives (default: under
# BACKLOG_DIR):
#LINE_ITEMS_STORE=%USERPROFILE%\Documents\DailyQueue\backlog\line_items.json
# Optional JSON file that EXTENDS the built-in normalization/tag rules with
# site wording — e.g. {"abbreviations": {"GRND": "GROUNDING"},
# "tags": {"SHAFT GROUNDING": ["grounding\\s*ring"]}}. After editing it, run
# `python line_items_scan.py --renorm` to re-apply to everything stored.
#LINE_ITEM_RULES=C:\path\to\line_item_rules.json

# Email is sent through your local Outlook desktop app — no password needed.
# Just the destination addresses:
EMAIL_TO=you@company.com
EMAIL_ALERT_TO=you@company.com

# ---------------------------------------------------------------------------
# Live intraday watcher (watch.py) — polls the board every couple of minutes,
# enriches only orders that are NEW since the last poll, and writes the current
# queue into a co-authored Excel workbook in real time (so coworkers see it
# update live). New orders fire a Windows toast + a Microsoft Teams card.
# ---------------------------------------------------------------------------
# The Microsoft 365 co-authored workbook to write the live queue into. Use the
# LOCAL OneDrive/SharePoint-synced path so the desktop Excel app (which the
# watcher drives via COM, just like the Outlook email) keeps it synced. The
# watcher writes/updates a sheet named "Live Queue" inside it. Leave blank to
# run the watcher without a live workbook (state + notifications still work).
#LIVE_WORKBOOK_PATH=%USERPROFILE%\OneDrive - Your Company\Daily Queue\Live Queue.xlsx
# How often to poll the board, in seconds. Default 120 (every 2 minutes).
#POLL_INTERVAL_SECONDS=120
# While a backlog scan is changing the similarity index continuously, refresh
# the heavy Similar Data tab at most this often. New/removed queue orders still
# refresh it immediately. Default 900 (15 minutes); 0 refreshes every store write.
#SIMILAR_REFRESH_INTERVAL_SECONDS=900
# The watcher drives the desktop Excel app over COM all day and never quits it, so
# Excel's memory slowly climbs (fragmented conditional-format rules, a growing calc
# chain, undo/redraw caches) — left alone it can reach multiple GB. Every this-many
# polls the watcher recycles the workbook: it closes it (AutoSave has already synced
# every edit; only the bot's own Excel is touched, so coworkers are unaffected) and
# the next poll reopens it fresh, reclaiming the memory. 30 polls ≈ 1 hour at the
# 120s default. Set 0 to disable. Tip: also fully close Excel overnight so the
# baseline resets — the watcher reattaches to a stale Excel each morning otherwise.
#EXCEL_RECYCLE_EVERY_POLLS=30
# Daily watch window (local 24h time). Default 05:00–17:00 (5am–5pm). Launch the
# watcher at/after WATCH_START (Task Scheduler); it stops itself at WATCH_END.
#WATCH_START=05:00
#WATCH_END=17:00
# Microsoft Teams webhook URL — when set, each new order is posted to that
# channel so coworkers + their phones get notified (no per-PC install). Both
# webhook types are auto-detected and supported:
#   - Workflows (recommended; replaces the retiring connector): in Teams, channel
#     ··· → Workflows → "Post to a channel when a webhook request is received" →
#     pick the channel → copy the URL (a *.logic.azure.com address).
#   - Legacy Incoming Webhook connector (being retired): channel ··· → Connectors
#     → Incoming Webhook → Create → copy the URL.
#TEAMS_WEBHOOK_URL=https://prod-00.westus.logic.azure.com:443/workflows/...
# Pop a Windows toast on the watcher PC for each new order (default on). Set to
# 0 to silence local pop-ups while keeping Teams. (pip install winotify for the
# nicer toast; otherwise a PowerShell balloon is used.)
#LIVE_TOAST=1
# Save a dated, frozen copy of the workbook at the first poll each morning, under
# OUTPUT_DIR\live_snapshots\. Default on; set to 0 to skip.
#LIVE_MORNING_SNAPSHOT=1
# Shareable WEB link to the live workbook (in Excel/OneDrive: Share -> Copy link).
# The daily 5 AM email sends this as an active link so the team opens the live
# sheet instead of a stale attachment. Leave blank to attach the dated file.
#LIVE_WORKBOOK_LINK=https://yourcompany.sharepoint.com/:x:/r/sites/...
# Whether the daily email still attaches the dated .xlsx. Defaults off once a
# live link is set (on otherwise). Force with 1/0. The dated file is always saved
# to disk for the archive regardless.
#EMAIL_ATTACH_REPORT=0
