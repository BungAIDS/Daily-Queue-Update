# CBC Insider — no password stored. Run `python login.py` once to log in
# manually; your session is saved to the file below and reused each day.
CBC_URL=https://www.cbcinsider.com
# Strongly recommended: paste the exact URL of your dispatch/queue page (the
# one ending in dispatch.aspx) from your browser's address bar. The scraper
# goes straight there; without it, it can't reliably find your queue.
CBC_QUEUE_URL=https://www.cbcinsider.com/intranet/offsyte/dispatch.aspx
# Optional but recommended: the Work Center your queue is filtered to (e.g.
# ENGGL). If set, the run aborts with a clear error rather than silently
# scraping a different Work Center should the site's selection ever drift.
CBC_WORK_CENTER=
# Backfill only (backfill_orders.py): the queue page's "search order" box is
# auto-detected. If detection misses on your layout, set its exact CSS selector
# here (run `python discover_documents.py --probe <job#>` to print it), and set
# CBC_SEARCH_BUTTON if a separate button — not Enter — submits the search.
#CBC_SEARCH_SELECTOR=#MainContent_txtFindOrder
#CBC_SEARCH_BUTTON=#MainContent_btnFindOrder
# Where the saved login session is stored (created by login.py).
STORAGE_STATE_PATH=./cbc_session.json

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Where to save the daily Excel files and JSON snapshots. Defaults to
# %USERPROFILE%\Documents\DailyQueue on Windows — uncomment + edit only if
# you want them somewhere else.
#OUTPUT_DIR=%USERPROFILE%\Documents\DailyQueue
#SNAPSHOT_DIR=%USERPROFILE%\Documents\DailyQueue\snapshots

# Where downloaded sales-order PDFs are archived (one subfolder per job).
# Defaults to the Z: drive share below. For the scheduled 5 AM task a UNC path
# (\\server\share\DAG\SALES ORDERS FOR DAILY QUEUE) is more reliable than a
# mapped drive letter.
#SALES_ORDER_DIR=Z:\DAG\SALES ORDERS FOR DAILY QUEUE
# Where downloaded construction/drive-run PDFs are archived (one subfolder per
# job). Only the highly-custom orders that have a quote/drive run get one.
#DRIVE_RUN_DIR=Z:\DAG\DRIVE RUNS FOR DAILY QUEUE
# How quote runs are recognized. Only HDX fans file the run under its own pid
# type (DRIVE_RUN_TYPES, comma-separated, case-insensitive, leading CBC_
# optional; any other doc type ending in "Run" also counts). Everything else
# files it under a generic type like CBC_Inquiry, recognizable only by FILE
# NAME — DRIVE_RUN_NAME_PATTERNS is a comma-separated list of case-insensitive
# regexes matched against document/file names, both in the order's documents
# and in the job's AutoCAD folder (searched recursively, e.g. ENG REF\
# "420410 qt  run.txt"). Extend the patterns as new namings turn up; run
# `python discover_documents.py <job#>` to see what a job carries.
#DRIVE_RUN_TYPES=CBC_DriveRun,CBC_QuoteRun
#DRIVE_RUN_NAME_PATTERNS=qt\s*run,quote\s*run,d64\s+wheel\s+construction
# Where the backlog tools (autocad_scan.py, backfill_orders.py) keep their
# resumable progress stores and master workbooks. Defaults under OUTPUT_DIR.
#BACKLOG_DIR=%USERPROFILE%\Documents\DailyQueue\backlog
# Root of the AutoCAD job folders (for the DWG scan + folder links).
#AUTOCAD_JOBS_DIR=Z:\AUTOCAD\CURRENT\JOBS
# How many order-detail pop-ups to open in parallel when fetching sales orders
# (each takes ~30s to load). Default 8. Raise cautiously and watch the server.
#SO_CONCURRENCY=8

# Sales-order LINE ITEMS: every parsed order's item/feature lines are captured,
# normalized, and stored for lookup (search with find_orders.py; build/tune the
# store with line_items_scan.py). Where the JSON store lives (default: under
# BACKLOG_DIR):
#LINE_ITEMS_STORE=%USERPROFILE%\Documents\DailyQueue\backlog\line_items.json
# Optional JSON file that EXTENDS the built-in normalization/tag rules with
# site wording — e.g. {"abbreviations": {"GRND": "GROUNDING"},
# "tags": {"SHAFT GROUNDING": ["grounding\\s*ring"]}}. After editing it, run
# `python line_items_scan.py --renorm` to re-apply to everything stored.
#LINE_ITEM_RULES=C:\path\to\line_item_rules.json

# Email is sent through your local Outlook desktop app — no password needed.
# Just the destination addresses:
EMAIL_TO=you@company.com
EMAIL_ALERT_TO=you@company.com
