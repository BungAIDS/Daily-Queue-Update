# CBC Insider — no password stored. Run `python login.py` once to log in
# manually; your session is saved to the file below and reused each day.
CBC_URL=https://www.cbcinsider.com
# Strongly recommended: paste the exact URL of your dispatch/queue page (the
# one ending in dispatch.aspx) from your browser's address bar. The scraper
# goes straight there; without it, it can't reliably find your queue.
CBC_QUEUE_URL=https://www.cbcinsider.com/intranet/offsyte/dispatch.aspx
# Optional but recommended: the Work Center your queue is filtered to (e.g.
# ENGGL). If set, the run aborts with a clear error rather than silently
# scraping a different Work Center should the site's selection ever drift.
CBC_WORK_CENTER=
# Where the saved login session is stored (created by login.py).
STORAGE_STATE_PATH=./cbc_session.json

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Where to save the daily Excel files and JSON snapshots. Defaults to
# %USERPROFILE%\Documents\DailyQueue on Windows — uncomment + edit only if
# you want them somewhere else.
#OUTPUT_DIR=%USERPROFILE%\Documents\DailyQueue
#SNAPSHOT_DIR=%USERPROFILE%\Documents\DailyQueue\snapshots

# Where downloaded sales-order PDFs are archived (one subfolder per job).
# Defaults to the Z: drive share below. For the scheduled 5 AM task a UNC path
# (\\server\share\DAG\SALES ORDERS FOR DAILY QUEUE) is more reliable than a
# mapped drive letter.
#SALES_ORDER_DIR=Z:\DAG\SALES ORDERS FOR DAILY QUEUE
# How many order-detail pop-ups to open in parallel when fetching sales orders
# (each takes ~30s to load). Default 8. Raise cautiously and watch the server.
#SO_CONCURRENCY=8

# Email is sent through your local Outlook desktop app — no password needed.
# Just the destination addresses:
EMAIL_TO=you@company.com
EMAIL_ALERT_TO=you@company.com
