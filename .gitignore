# Secrets and session — never commit these
.env
cbc_session.json

# Output
output/
snapshots/
*.xlsx
cron.log

# Watcher logs (rotated daily, kept ~a week) — runtime only, don't commit
logs/
watch.log*
launcher_logs/
.launcher_state.json

# Python
venv/
__pycache__/
*.pyc

# Scratch dir left behind by test_backfill_serial.py's runner
.tmp_backfill_serial_tests/

# Launcher<->script stop-flag files (runtime only)
.launcher_stops/

# Single-instance launcher lock (runtime only)
.launcher.lock
